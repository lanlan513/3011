  "quotes": [
    {
      "id": 1,
      "dramaId": 1,
      "text": "人善人欺天不欺，人恶人怕天不怕。",
      "character": "方展博"
    },
    {
      "id": 2,
      "dramaId": 1,
      "text": "我丁蟹对天发誓，我没有错！",
      "character": "丁蟹"
    },
    {
      "id": 3,
      "dramaId": 1,
      "text": "股市是一个很迷人的地方。",
      "character": "方展博"
    },
    {
      "id": 4,
      "dramaId": 2,
      "text": "靖哥哥，你怎么那么笨啊？",
      "character": "黄蓉"
    },
    {
      "id": 5,
      "dramaId": 2,
      "text": "蓉儿，我一定会保护你的。",
      "character": "郭靖"
    },
    {
      "id": 6,
      "dramaId": 3,
      "text": "大勇，我们又要开始查案了。",
      "character": "李忠义"
    },
    {
      "id": 9,
      "dramaId": 5,
      "text": "凉风有信，秋月无边。",
      "character": "韦小宝"
    },
    {
      "id": 10,
      "dramaId": 5,
      "text": "桂公公，你真是厉害啊！",
      "character": "双儿"
    },
    {
      "id": 11,
      "dramaId": 6,
      "text": "娥姐，我们上！",
      "character": "陈三元"
    },
    {
      "id": 12,
      "dramaId": 7,
      "text": "我乔峰要走，谁能拦我！",
      "character": "乔峰"
    },
    {
      "id": 13,
      "dramaId": 7,
      "text": "王姑娘，你怎么什么都知道？",
      "character": "段誉"
    },
    {
      "id": 14,
      "dramaId": 8,
      "text": "我叶荣添一定会成功的！",
      "character": "叶荣添"
    },
    {
      "id": 15,
      "dramaId": 8,
      "text": "做人最重要的是有梦想。",
      "character": "许文彪"
    },
    {
      "id": 17,
      "dramaId": 10,
      "text": "临、兵、斗、者、皆、阵、列、在、前，诛邪！",
      "character": "马小玲"
    },
    {
      "id": 18,
      "dramaId": 10,
      "text": "马家的女人，不能为男人流眼泪。",
      "character": "马小玲"
    },
    {
      "id": 19,
      "dramaId": 11,
      "text": "法律面前，人人平等。",
      "character": "余在春"
    },
    {
      "id": 20,
      "dramaId": 12,
      "text": "医生的天职就是救死扶伤。",
